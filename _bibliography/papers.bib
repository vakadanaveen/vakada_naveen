@inproceedings{vakada2025audioquery,
  abbr        = {EMNLP},
  title       = {Audio Query Handling System with Integrated Expert Models and Contextual Understanding},
  author      = {Vakada, Naveen and others},
  booktitle   = {Proceedings of the 2025 Conference on Empirical Methods in Natural Language Processing},
  year        = {2025},
  selected    = {true},
  bibtex_show = {true},
  abstract    = {A comprehensive chatbot system designed to handle a wide range of audio-related queries by integrating multiple specialized audio processing models. The system uses an intent classifier to route queries to expert models such as Automatic Speech Recognition and other audio understanding components.}
}

@article{vakada2026longaudiorag,
  abbr        = {arXiv},
  title       = {{LongAudio-RAG}: Event-Grounded Question Answering over Multi-Hour Long Audio},
  author      = {Vakada, Naveen and Hegde, Kartik and Sridhar, Arvind Krishna and Guo, Yinyi and Visser, Erik},
  journal     = {arXiv preprint arXiv:2602.14612},
  year        = {2026},
  arxiv       = {2602.14612},
  selected    = {true},
  bibtex_show = {true},
  abstract    = {Long-duration audio is increasingly common in industrial and consumer settings, yet reviewing multi-hour recordings is impractical. We introduce LongAudio-RAG (LA-RAG), a hybrid framework that grounds Large Language Model outputs in retrieved, timestamped acoustic event detections rather than raw audio. Multi-hour streams are converted into structured event records stored in an SQL database, and at inference time the system resolves natural-language time references, classifies intent, retrieves only the relevant events, and generates answers using this constrained evidence.}
}

